# Server
INTERVIEW_ADDR=:8080

# STT
INTERVIEW_STT_PROVIDER=sherpa

# LLM – set INTERVIEW_LLM_PROVIDER to one of the supported providers listed below.
# The provider-specific sections show which variables are relevant for each choice.
INTERVIEW_LLM_PROVIDER=openai-compatible

# Common LLM settings (apply to every provider unless overridden below)
INTERVIEW_LLM_MODEL=
INTERVIEW_LLM_SYSTEM_PROMPT=
INTERVIEW_LLM_TEMPERATURE=0.2
INTERVIEW_LLM_TIMEOUT=90s

# ---------------------------------------------------------------------------
# Sherpa STT
# ---------------------------------------------------------------------------
INTERVIEW_SHERPA_WS_URL=ws://localhost:6006/

# ---------------------------------------------------------------------------
# Tencent ASR
# ---------------------------------------------------------------------------
INTERVIEW_TENCENT_WS_URL=wss://asr.cloud.tencent.com/asr/v2/
INTERVIEW_TENCENT_APP_ID=
INTERVIEW_TENCENT_SECRET_ID=
INTERVIEW_TENCENT_SECRET_KEY=
INTERVIEW_TENCENT_ENGINE_TYPE=16k_zh
INTERVIEW_TENCENT_NEED_VAD=1
INTERVIEW_TENCENT_NO_EMPTY_RESULT=1

# ---------------------------------------------------------------------------
# Groq  (INTERVIEW_LLM_PROVIDER=groq)
# ---------------------------------------------------------------------------
# INTERVIEW_LLM_BASE_URL=https://api.groq.com/openai/v1
# INTERVIEW_LLM_API_KEY=
# GROQ_API_KEY=          # alternative to INTERVIEW_LLM_API_KEY
# INTERVIEW_LLM_MODEL=llama-3.3-70b-versatile

# ---------------------------------------------------------------------------
# OpenAI  (INTERVIEW_LLM_PROVIDER=openai)
# ---------------------------------------------------------------------------
# INTERVIEW_LLM_BASE_URL=https://api.openai.com/v1
# INTERVIEW_LLM_API_KEY=
# OPENAI_API_KEY=        # alternative to INTERVIEW_LLM_API_KEY
# INTERVIEW_LLM_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Anthropic / Claude  (INTERVIEW_LLM_PROVIDER=anthropic)
# ---------------------------------------------------------------------------
# INTERVIEW_LLM_BASE_URL=https://api.anthropic.com
# INTERVIEW_LLM_API_KEY=
# ANTHROPIC_API_KEY=     # alternative to INTERVIEW_LLM_API_KEY
# INTERVIEW_LLM_MODEL=claude-opus-4-5

# ---------------------------------------------------------------------------
# DeepSeek  (INTERVIEW_LLM_PROVIDER=deepseek)
# ---------------------------------------------------------------------------
# INTERVIEW_LLM_BASE_URL=https://api.deepseek.com/v1
# INTERVIEW_LLM_API_KEY=
# DEEPSEEK_API_KEY=      # alternative to INTERVIEW_LLM_API_KEY
# INTERVIEW_LLM_MODEL=deepseek-chat

# ---------------------------------------------------------------------------
# Zhipu AI / GLM  (INTERVIEW_LLM_PROVIDER=zhipu)
# ---------------------------------------------------------------------------
# INTERVIEW_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# INTERVIEW_LLM_API_KEY=
# ZHIPU_API_KEY=         # alternative to INTERVIEW_LLM_API_KEY
# INTERVIEW_LLM_MODEL=glm-4-flash

# ---------------------------------------------------------------------------
# Alibaba Qianwen / DashScope  (INTERVIEW_LLM_PROVIDER=qianwen)
# ---------------------------------------------------------------------------
# INTERVIEW_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# INTERVIEW_LLM_API_KEY=
# DASHSCOPE_API_KEY=     # alternative to INTERVIEW_LLM_API_KEY
# INTERVIEW_LLM_MODEL=qwen-max

# ---------------------------------------------------------------------------
# Moonshot AI / Kimi  (INTERVIEW_LLM_PROVIDER=moonshot)
# ---------------------------------------------------------------------------
# INTERVIEW_LLM_BASE_URL=https://api.moonshot.cn/v1
# INTERVIEW_LLM_API_KEY=
# MOONSHOT_API_KEY=      # alternative to INTERVIEW_LLM_API_KEY
# INTERVIEW_LLM_MODEL=moonshot-v1-8k

# ---------------------------------------------------------------------------
# Google Gemini  (INTERVIEW_LLM_PROVIDER=gemini)
# ---------------------------------------------------------------------------
# INTERVIEW_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# INTERVIEW_LLM_API_KEY=
# GEMINI_API_KEY=        # alternative to INTERVIEW_LLM_API_KEY
# INTERVIEW_LLM_MODEL=gemini-2.0-flash

# ---------------------------------------------------------------------------
# Ollama (local)  (INTERVIEW_LLM_PROVIDER=ollama)
# ---------------------------------------------------------------------------
# INTERVIEW_LLM_BASE_URL=http://127.0.0.1:11434/v1
# INTERVIEW_LLM_API_KEY=ollama
# INTERVIEW_LLM_MODEL=qwen2.5:7b

# ---------------------------------------------------------------------------
# Generic OpenAI-compatible endpoint  (INTERVIEW_LLM_PROVIDER=openai-compatible)
# ---------------------------------------------------------------------------
# INTERVIEW_LLM_BASE_URL=http://127.0.0.1:1234/v1
# INTERVIEW_LLM_API_KEY=
# INTERVIEW_LLM_MODEL=local-model
