# Server
INTERVIEW_ADDR=:8080

# STT
INTERVIEW_STT_PROVIDER=sherpa

# LLM – set INTERVIEW_LLM_PROVIDER to one of the supported providers listed below.
INTERVIEW_LLM_PROVIDER=groq

# Common LLM settings (apply to every provider)
# INTERVIEW_LLM_MODEL=        # optional: overrides the provider-specific model below
INTERVIEW_LLM_SYSTEM_PROMPT=
INTERVIEW_LLM_TEMPERATURE=0.2
INTERVIEW_LLM_TIMEOUT=90s

# ---------------------------------------------------------------------------
# Sherpa STT
# ---------------------------------------------------------------------------
INTERVIEW_SHERPA_WS_URL=ws://localhost:6006/

# ---------------------------------------------------------------------------
# Tencent ASR
# ---------------------------------------------------------------------------
INTERVIEW_TENCENT_WS_URL=wss://asr.cloud.tencent.com/asr/v2/
INTERVIEW_TENCENT_APP_ID=
INTERVIEW_TENCENT_SECRET_ID=
INTERVIEW_TENCENT_SECRET_KEY=
INTERVIEW_TENCENT_ENGINE_TYPE=16k_zh
INTERVIEW_TENCENT_NEED_VAD=1
INTERVIEW_TENCENT_NO_EMPTY_RESULT=1

# ---------------------------------------------------------------------------
# Groq  (INTERVIEW_LLM_PROVIDER=groq)
# ---------------------------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# ---------------------------------------------------------------------------
# OpenAI  (INTERVIEW_LLM_PROVIDER=openai)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# Anthropic / Claude  (INTERVIEW_LLM_PROVIDER=anthropic)
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-5

# ---------------------------------------------------------------------------
# DeepSeek  (INTERVIEW_LLM_PROVIDER=deepseek)
# ---------------------------------------------------------------------------
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# ---------------------------------------------------------------------------
# Zhipu AI / GLM  (INTERVIEW_LLM_PROVIDER=zhipu)
# ---------------------------------------------------------------------------
# ZHIPU_API_KEY=
# ZHIPU_MODEL=glm-4-flash

# ---------------------------------------------------------------------------
# Alibaba Qianwen / DashScope  (INTERVIEW_LLM_PROVIDER=qianwen)
# ---------------------------------------------------------------------------
# DASHSCOPE_API_KEY=
# DASHSCOPE_MODEL=qwen-max

# ---------------------------------------------------------------------------
# Moonshot AI / Kimi  (INTERVIEW_LLM_PROVIDER=moonshot)
# ---------------------------------------------------------------------------
# MOONSHOT_API_KEY=
# MOONSHOT_MODEL=moonshot-v1-8k

# ---------------------------------------------------------------------------
# Google Gemini  (INTERVIEW_LLM_PROVIDER=gemini)
# ---------------------------------------------------------------------------
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# ---------------------------------------------------------------------------
# Ollama (local)  (INTERVIEW_LLM_PROVIDER=ollama)
# ---------------------------------------------------------------------------
# OLLAMA_MODEL=qwen2.5:7b

# ---------------------------------------------------------------------------
# Generic OpenAI-compatible endpoint  (INTERVIEW_LLM_PROVIDER=openai-compatible)
# ---------------------------------------------------------------------------
# INTERVIEW_LLM_BASE_URL=http://127.0.0.1:1234/v1
# INTERVIEW_LLM_API_KEY=
# INTERVIEW_LLM_MODEL=local-model
