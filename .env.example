# Server
INTERVIEW_ADDR=:8080

# STT
INTERVIEW_STT_PROVIDER=sherpa

# LLM – set INTERVIEW_LLM_PROVIDER to one of the supported providers listed below.
INTERVIEW_LLM_PROVIDER=groq

# Common LLM settings (apply to every provider)
# INTERVIEW_LLM_MODEL=        # optional: overrides the provider-specific model below
INTERVIEW_LLM_SYSTEM_PROMPT=
INTERVIEW_LLM_TEMPERATURE=0.2
INTERVIEW_LLM_TIMEOUT=90s

# ---------------------------------------------------------------------------
# RAG / Knowledge Base (optional)
# ---------------------------------------------------------------------------
# Option A: interviewd directly loads local .md/.txt files and calls an
# embedding endpoint compatible with tools/sentence_transformers_server.py.
# INTERVIEW_KNOWLEDGE_LOCAL_PATH=./knowledge
# INTERVIEW_KNOWLEDGE_EMBEDDING_ENDPOINT=http://127.0.0.1:7008/embed
# INTERVIEW_KNOWLEDGE_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# INTERVIEW_KNOWLEDGE_MAX_RESULTS=5
# INTERVIEW_KNOWLEDGE_TIMEOUT=10s

# Option B: use a separate search service such as `go run ./cmd/kbd`.
# INTERVIEW_KNOWLEDGE_ENDPOINT=http://127.0.0.1:7007/search
# INTERVIEW_KNOWLEDGE_LOCAL_ADDR=:7007

# ---------------------------------------------------------------------------
# Sherpa STT
# ---------------------------------------------------------------------------
INTERVIEW_SHERPA_WS_URL=ws://localhost:6006/

# ---------------------------------------------------------------------------
# Tencent ASR
# ---------------------------------------------------------------------------
INTERVIEW_TENCENT_WS_URL=wss://asr.cloud.tencent.com/asr/v2/
INTERVIEW_TENCENT_APP_ID=
INTERVIEW_TENCENT_SECRET_ID=
INTERVIEW_TENCENT_SECRET_KEY=
INTERVIEW_TENCENT_ENGINE_TYPE=16k_zh
INTERVIEW_TENCENT_NEED_VAD=1
INTERVIEW_TENCENT_NO_EMPTY_RESULT=1

# ---------------------------------------------------------------------------
# Groq  (INTERVIEW_LLM_PROVIDER=groq)
# ---------------------------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# ---------------------------------------------------------------------------
# OpenAI  (INTERVIEW_LLM_PROVIDER=openai)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# Anthropic / Claude  (INTERVIEW_LLM_PROVIDER=anthropic)
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-5
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ---------------------------------------------------------------------------
# DeepSeek  (INTERVIEW_LLM_PROVIDER=deepseek)
# ---------------------------------------------------------------------------
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ---------------------------------------------------------------------------
# Zhipu AI / GLM  (INTERVIEW_LLM_PROVIDER=zhipu)
# ---------------------------------------------------------------------------
# ZHIPU_API_KEY=
# ZHIPU_MODEL=glm-4-flash
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ---------------------------------------------------------------------------
# Alibaba Qianwen / DashScope  (INTERVIEW_LLM_PROVIDER=qianwen)
# ---------------------------------------------------------------------------
# DASHSCOPE_API_KEY=
# DASHSCOPE_MODEL=qwen-max
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---------------------------------------------------------------------------
# Moonshot AI / Kimi  (INTERVIEW_LLM_PROVIDER=moonshot)
# ---------------------------------------------------------------------------
# MOONSHOT_API_KEY=
# MOONSHOT_MODEL=moonshot-v1-8k
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# ---------------------------------------------------------------------------
# Google Gemini  (INTERVIEW_LLM_PROVIDER=gemini)
# ---------------------------------------------------------------------------
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# ---------------------------------------------------------------------------
# Ollama (local)  (INTERVIEW_LLM_PROVIDER=ollama)
# ---------------------------------------------------------------------------
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1

# ---------------------------------------------------------------------------
# vLLM (local)  (INTERVIEW_LLM_PROVIDER=vllm)
# ---------------------------------------------------------------------------
# VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# VLLM_BASE_URL=http://127.0.0.1:8000/v1
# VLLM_API_KEY=

# ---------------------------------------------------------------------------
# Generic OpenAI-compatible endpoint  (INTERVIEW_LLM_PROVIDER=openai-compatible)
# ---------------------------------------------------------------------------
# INTERVIEW_LLM_BASE_URL=http://127.0.0.1:1234/v1
# INTERVIEW_LLM_API_KEY=
# INTERVIEW_LLM_MODEL=local-model
